# =============================================================================
# .env.example — template for required environment variables
# =============================================================================
#
# Copy this file to .env (gitignored) and fill in real values for local dev.
#
#   cp .env.example .env
#
# In staging/prod, do NOT use a .env file — set these as real environment
# variables via your platform (Docker, k8s Secret, AWS task def, etc.).
#
# Every key listed here is required and validated at boot by validateEnv
# (src/config/env-config.ts). Missing or invalid values will abort startup.
# =============================================================================

# Runtime mode. One of: dev | staging | prod
NODE_ENV=dev

# HTTP port the app listens on. Integer in range 1–65535.
PORT=3000

# Postgres connection URL. Must use postgres:// or postgresql:// scheme.
# Local example: postgres://user:password@localhost:5432/userdb
DB_URL=

# Secret used to sign JWTs. Must be at least 32 characters.
# Generate with: openssl rand -hex 32
JWT_SECRET=
